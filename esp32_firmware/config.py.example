"""
配置文件 - 太空农业种植舱
修改此文件以适配你的硬件和网络环境

使用方法: 复制本文件为 config.py，并填入你的实际配置
  cp config.py.example config.py
"""

import sys


def _load_secret(key, default=""):
    """从 /secrets/ 目录安全加载密钥（避免明文存储）"""
    try:
        with open(f"/secrets/{key}", "r") as f:
            return f.read().strip()
    except OSError:
        # 文件不存在时返回默认值（正常情况，首次使用时密钥文件尚未创建）
        return default


# ============ WiFi 配置 ============
WIFI_SSID = "YOUR_WIFI_SSID"
WIFI_PASSWORD = _load_secret("wifi_pass", "YOUR_WIFI_PASSWORD")

# ============ AI API 配置 ============
# DeepSeek 官方 API（OpenAI 兼容格式）
# 注册地址: https://platform.deepseek.com/
AI_API_URL = "https://api.deepseek.com/chat/completions"
AI_API_KEY = _load_secret("api_key", "YOUR_API_KEY_HERE")
AI_MODEL = "deepseek-v4-flash"
AI_TIMEOUT = 20  # API超时时间（秒），推理模型需要较长等待
AI_MIN_FREE_MEM = 110000  # 低于该空闲内存时跳过云端 AI，避免 ESP32 TLS 握手失败
AI_PROXY_URL = ""  # 可填局域网代理，例如 "http://192.168.125.2:8787/decision"
AI_PROXY_TOKEN = ""  # 可选：代理访问令牌，需与云端 AI_PROXY_TOKEN 一致

# ============ 系统参数 ============
READ_INTERVAL = 60        # 传感器读取间隔（秒），不低于 60 秒（正式运行建议 300 秒 = 5 分钟）
MIN_ACTION_INTERVAL = 60  # 最小动作间隔（秒），防止频繁动作
MAX_ACTIONS_PER_HOUR = 12  # 每小时最大动作次数
MAX_ERRORS = 10           # 最大连续错误次数，超过后重启

# ============ 种植日期 ============
# 格式: (年, 月, 日)，系统据此计算种植天数和生长阶段
# 每次重新种植时更新此值
PLANTING_DATE = (2026, 5, 1)  # 例: 2026年5月1日播种

# ============ GPIO 引脚定义 ============
# 传感器
SOIL_ADC_PIN = 34         # 土壤湿度 ADC 引脚

# 温湿度传感器（DHT11 或 DHT22）
DHT_PIN = 4
DHT_TYPE = "DHT11"  # 可选: "DHT11" 或 "DHT22"

# 继电器（低电平触发）
RELAY_WATER_PIN = 5       # 水泵继电器
RELAY_NUTRIENT_PIN = 18   # 营养液泵继电器
RELAY_FAN_PIN = 19        # 风扇继电器

# 拨码开关（3位拨码开关，支持 8 种组合）
# bit0~bit2 对应 DIP 开关的第1~第3位
# 使用 PULL_UP 输入：开关 OFF(断开)→1→取反为0, ON(接地)→0→取反为1
DIP_SWITCH_PINS = [13, 12, 14]

# OLED 显示屏 (I2C)
OLED_SDA_PIN = 21
OLED_SCL_PIN = 22
OLED_I2C_FREQ = 400000

# 状态LED
LED_RED_PIN = 27
LED_GREEN_PIN = 26

# ============ 传感器参数 ============
# 土壤湿度参数
SOIL_SENSOR_MODE = "adc"  # 可选: "adc" 电容式模拟量 / "digital" 比较器数字量
SOIL_ADC_MAX = 4095       # 干土 ADC 值
SOIL_ADC_MIN = 1500       # 湿土 ADC 值
SOIL_DIGITAL_DRY_VALUE = 1  # 数字土壤传感器干燥时的输出值，请按模块实际输出调整

# ============ 执行器参数 ============
PUMP_WATER_DEFAULT_SEC = 8     # 默认浇水时长（秒）
PUMP_NUTRIENT_DEFAULT_SEC = 5 # 默认营养液时长（秒）
FAN_DEFAULT_SEC = 30          # 默认换气时长（秒）
PUMP_MAX_RUN_SEC = 60          # 单次最大运行时长（安全限制）

# ============ 植物数据库 ============
# PLANT_DB 已迁移至 plants.json（节省 RAM）
# 如需添加新植物，请编辑 plants.json 文件

# ============ 3位拨码开关编码表（0~7） ============
# 编码: bit0=DIP1, bit1=DIP2, bit2=DIP3
# 0~7: 预定义植物（见 plants.json）
DIP_ENCODING = {
    0: "生菜",      # 叶菜
    1: "小白菜",    # 叶菜
    2: "菠菜",      # 叶菜
    3: "韭菜",      # 叶菜
    4: "番茄",      # 果菜
    5: "辣椒",      # 果菜
    6: "黄瓜",      # 果菜
    7: "茄子",      # 果菜
}


def get_plant_name(index):
    """根据拨码值获取植物名称（支持 0-7，共 8 种）"""
    return DIP_ENCODING.get(index, "生菜")  # 默认返回生菜


def get_plant_info(plant_name):
    """获取植物参数（动态加载，避免占用大量内存）"""
    import ujson
    import gc

    plant_data = None
    try:
        with open('plants.json', 'r', encoding='utf-8') as f:
            db = ujson.load(f)
            plant_data = db.get(plant_name)
            if not plant_data:
                plant_data = db.get("生菜")
    except Exception as e:
        print(f"Error loading plants.json: {e}")
        # Fallback minimal data if file missing or corrupt
        plant_data = {
            "soil_threshold": 30,
            "water_sec": 8, "nutrient_sec": 5, "ventilate_sec": 30,
            "nutrient_interval": 259200,
            "growth_stages": [{"days": [0, 999], "stage": "vegetative", "fert": "NPK", "water_need": "normal", "note": ""}]
        }

    # 彻底释放包含整个 JSON 的 db 字典内存
    gc.collect()
    return plant_data


def get_growth_stage(plant_info, days_since_planting):
    """
    根据种植天数获取当前生长阶段
    返回: 当前阶段字典，包含 stage/fert/water_need/note
    """
    stages = plant_info.get("growth_stages", [])
    if not stages:
        return {"stage": "unknown", "fert": "NPK", "water_need": "normal", "note": "无阶段数据"}

    for s in stages:
        days = s.get("days", [0, 0])
        start_day = days[0] if isinstance(days, (list, tuple)) and len(days) > 0 else 0
        end_day = days[1] if isinstance(days, (list, tuple)) and len(days) > 1 else 999

        if start_day <= days_since_planting <= end_day:
            return s

    # 超出所有阶段范围，返回最后一个
    return stages[-1]


def calc_days_since_planting():
    """计算从种植日期到今天的天数"""
    import time
    planting = PLANTING_DATE  # (年, 月, 日)
    now = time.localtime()

    try:
        then_sec = time.mktime((planting[0], planting[1], planting[2], 0, 0, 0, 0, 0))
        now_sec = time.mktime((now[0], now[1], now[2], 0, 0, 0, 0, 0))
        days = int((now_sec - then_sec) / 86400)
        return max(0, days)
    except (ValueError, OverflowError):
        days = (now[0] - planting[0]) * 365 + (now[1] - planting[1]) * 30 + (now[2] - planting[2])
        return max(0, days)
