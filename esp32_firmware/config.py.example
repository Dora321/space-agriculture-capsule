"""
配置文件 - 太空农业种植舱
修改此文件以适配你的硬件和网络环境

使用方法: 复制本文件为 config.py，并填入你的实际配置
  cp config.py.example config.py
"""

import sys


def _load_secret(key, default=""):
    """从 /secrets/ 目录安全加载密钥（避免明文存储）"""
    try:
        with open(f"/secrets/{key}", "r") as f:
            return f.read().strip()
    except OSError:
        # 文件不存在时返回默认值（正常情况，首次使用时密钥文件尚未创建）
        return default


# ============ WiFi 配置 ============
WIFI_SSID = "YOUR_WIFI_SSID"
WIFI_PASSWORD = _load_secret("wifi_pass", "YOUR_WIFI_PASSWORD")
WIFI_CONNECT_TIMEOUT = 12       # 开机首次连接最多等待秒数，避免卡在 WiFi
WIFI_RECONNECT_TIMEOUT = 12     # 主循环断线重连单次最多等待秒数
WIFI_RECONNECT_INTERVAL = 120   # 断线后两次重连尝试的最小间隔秒数
WIFI_LINK_GRACE_MS = 5000       # 运行期短暂 IP=0.0.0.0 时先等待自恢复，避免误触发重连
WIFI_DISABLE_POWER_SAVE = True  # 关闭 ESP32 WiFi 省电，提升热点/云端连接稳定性
NTP_SYNC_ON_CONNECT = False     # 比赛现场优先稳定性；需要准确 RTC 时再改 True

