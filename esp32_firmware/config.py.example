"""
配置文件 - 太空农业种植舱
修改此文件以适配你的硬件和网络环境

使用方法: 复制本文件为 config.py，并填入你的实际配置
  cp config.py.example config.py
"""

import sys


def _load_secret(key, default=""):
    """从 /secrets/ 目录安全加载密钥（避免明文存储）"""
    try:
        with open(f"/secrets/{key}", "r") as f:
            return f.read().strip()
    except OSError:
        # 文件不存在时返回默认值（正常情况，首次使用时密钥文件尚未创建）
        return default


# ============ 联网 / AI / 大屏：已全部移到树莓派侧 ============
# 双层架构（2026-05-30）：ESP32 不再使用 WiFi、不直连 DeepSeek、不直传遥测。
# 树莓派经 UART 负责联网、调 DeepSeek（advice 回传）、转发大屏。
# 因此本文件不再有 WIFI_* / AI_* / DASHBOARD_* / TELEMETRY_* 配置。
# DeepSeek 的 API key/model 等改在树莓派侧用环境变量配置，见 tools/serial_gateway.py。

# ============ Raspberry Pi UART Link ============
# ESP32（飞控）<-> 树莓派（载荷计算机）UART2 链路。这是固件的唯一上行/下行通道。
# 接线：ESP32 GPIO17(U2 TX) -> Pi GPIO15/RXD(pin10)，GPIO16(U2 RX) <- Pi GPIO14/TXD(pin8)，GND 共地。
UART_ID = 2
UART_BAUD = 115200
UART_TX_PIN = 17       # ESP32 U2 TX -> Raspberry Pi GPIO15/RXD (pin 10)
UART_RX_PIN = 16       # ESP32 U2 RX <- Raspberry Pi GPIO14/TXD (pin 8)
UART_RXBUF = 256       # keep UART driver memory small on MicroPython
UART_OFFLINE_TIMEOUT_MS = 30000

# ============ 系统参数 ============
READ_INTERVAL = 60        # 传感器读取间隔（秒），不低于 60 秒（正式运行建议 300 秒 = 5 分钟）
DECISION_INTERVAL = 60    # 本地动作决策间隔（秒），默认每分钟随采样判断一次；云端 AI 另有请求门控
PAGE_ROTATE_SEC = 0       # OLED 页面切换：0=手动（红/黄按键），>0=自动轮播秒数
STARTUP_MENU_ON_BOOT = False  # False=开机直接运行；True=开机先选作物/天数
MIN_ACTION_INTERVAL = 60  # 最小动作间隔（秒），防止频繁动作
MAX_ACTIONS_PER_HOUR = 12  # 每小时最大动作次数
MAX_ERRORS = 10           # 最大连续错误次数，超过后重启

# ============ 参赛演示模式 ============
# DEMO_MODE=True 时不读取真实传感器，而是用模拟数据快速展示：
# 正常 -> 土壤变干 -> 自动浇水 -> 湿度恢复。
DEMO_MODE = False
DEMO_READ_INTERVAL = 5
DEMO_PLANT_TYPE = "生菜"

# 展示模式（读真实传感器但快速响应）——由菜单「Demo Speed」运行时切换，无需改本文件。
# 开启后读取/决策间隔缩到 FAST_READ_INTERVAL 秒，且跳过动作限频，
# 便于现场遮挡光照/土壤传感器后几秒内看到补光/浇水反应。
FAST_READ_INTERVAL = 3
FAST_MODE_ON_BOOT = True   # 开机即进入展示模式（快速响应）；设 False 则开机用正常间隔
DEMO_START_SOIL = 42
DEMO_SOIL_DROP = 7
DEMO_RECOVER_SOIL = 55
DEMO_LIGHT_LEVEL = 72
DEMO_TEMPERATURE = 24.5
DEMO_HUMIDITY = 62

# ============ 种植日期 ============
# 格式: (年, 月, 日)，系统据此计算种植天数和生长阶段
# 每次重新种植时更新此值
PLANTING_DATE = (2026, 5, 1)  # 例: 2026年5月1日播种

# ============ GPIO 引脚定义 ============
# 传感器
SOIL_ADC_PIN = 34         # 土壤湿度 ADC 引脚
LIGHT_ADC_PIN = 32        # 环境亮度 ADC 引脚（HS-S20L-B）

# 温湿度传感器（DHT11 或 DHT22）
DHT_PIN = 4
DHT_TYPE = "DHT11"  # 可选: "DHT11" 或 "DHT22"

# 继电器（低电平触发）
RELAY_WATER_PIN = 5       # 水泵继电器（12V 蠕动泵）
RELAY_LIGHT_PIN = 18      # 补光灯继电器（12V COB 灯条）

# 菜单输入设备
# 模拟键盘（ADC 电阻分压，所有按键共用 GPIO33）
# 电路：VCC(3.3V) → R_pullup → GPIO33 → 各按键电阻 → 开关 → GND
# 不同按键产生不同 ADC 电压，通过阈值区分
ANALOG_KEYPAD_PIN = 33
# 可选：自定义 ADC 阈值
# ANALOG_KEYPAD_THRESHOLDS = {"up": (0, 300), "down": (301, 900), "ok": (901, 1800), "back": (1801, 3200)}

# OLED 显示屏 (I2C)
OLED_SDA_PIN = 21
OLED_SCL_PIN = 22
OLED_I2C_FREQ = 400000

# WS2812 状态灯条（11 颗灯珠的可寻址 RGB 灯条）
# 用作「育种舱生物指示灯」：
#   - 平时：按土壤湿度点亮对应数量灯珠（每颗约 9%），颜色梯度暖红→绿→冷蓝
#   - 浇水中：整条黄色脉冲呼吸
#   - 错误/离线：整条红色闪烁
WS2812_PIN = 26
WS2812_LED_COUNT = 11
WS2812_ENABLED = True     # 2026-06-03 启用：电源实测通过，常亮展示决策信号灯效
WS2812_BRIGHTNESS = 0.6   # 0.0-1.0；0.6 实测可见度好。注意峰值电流随亮度上升
WS2812_PLAY_IDLE_ADVISORY = True
WS2812_PLAY_ACTION_ADVISORY = True

# ============ 传感器参数 ============
# 土壤湿度参数
SOIL_SENSOR_MODE = "adc"  # 可选: "adc" 电容式模拟量 / "digital" 比较器数字量
SOIL_ADC_MAX = 4095       # 干土 ADC 值
SOIL_ADC_MIN = 1500       # 湿土 ADC 值
SOIL_DIGITAL_DRY_VALUE = 1  # 数字土壤传感器干燥时的输出值，请按模块实际输出调整
LIGHT_ADC_MAX = 4095      # 亮度传感器 ADC 最大值
LIGHT_ADC_MIN = 0         # 亮度传感器 ADC 最小值
LIGHT_INVERT = True       # True: ADC 越大越暗；False: ADC 越大越亮

# ============ 执行器参数 ============
PUMP_WATER_DEFAULT_SEC = 8     # 默认浇水时长（秒）
PUMP_MAX_RUN_SEC = 20          # 水泵单次最大运行时长（安全限制）
LIGHT_MAX_RUN_SEC = 20         # 补光灯单次最大运行时长（安全限制）

# ============ 温度安全护栏 ============
# 超过 TEMP_HIGH_C 视为高温，跳过浇水避免叶面灼伤 + 闷根
# 低于 TEMP_LOW_C 视为低温，跳过浇水避免冻根
# 注：太空舱内温度异常通常表示热控失效，决策上保守为先
TEMP_HIGH_C = 35   # 高温警戒线（℃）
TEMP_LOW_C = 8     # 低温警戒线（℃）

# ============ 植物数据库 ============
# PLANT_DB 已迁移至 plants.json（节省 RAM）
# 如需添加新植物，请编辑 plants.json 文件

# ============ 植物列表（有序，供独立按钮菜单使用，含 8 种植物） ============
PLANT_LIST = [
    "生菜",      # 0: 叶菜
    "小白菜",    # 1: 叶菜
    "菠菜",      # 2: 叶菜
    "韭菜",      # 3: 叶菜
    "番茄",      # 4: 果菜
    "辣椒",      # 5: 果菜
    "黄瓜",      # 6: 果菜
    "茄子",      # 7: 果菜
]


def get_plant_name(index):
    """根据索引获取植物名称（0-7，共 8 种）"""
    return PLANT_LIST[index] if 0 <= index < len(PLANT_LIST) else "生菜"  # 默认返回生菜


def get_plant_info(plant_name):
    """获取植物参数（动态加载，避免占用大量内存）"""
    import ujson
    import gc

    plant_data = None
    try:
        with open('plants.json', 'r', encoding='utf-8') as f:
            db = ujson.load(f)
            plant_data = db.get(plant_name)
            if not plant_data:
                plant_data = db.get("生菜")
    except Exception as e:
        print(f"Error loading plants.json: {e}")
        # Fallback minimal data if file missing or corrupt
        plant_data = {
            "soil_threshold": 30,
            "light_min": 10, "light_opt": 50, "light_hours": [6, 8],
            "water_sec": 8,
            "growth_stages": [{"days": [0, 999], "stage": "vegetative", "fert": "NPK", "water_need": "normal", "note": ""}]
        }

    # 彻底释放包含整个 JSON 的 db 字典内存
    gc.collect()
    return plant_data


def get_growth_stage(plant_info, days_since_planting):
    """
    根据种植天数获取当前生长阶段
    返回: 当前阶段字典，包含 stage/fert/water_need/note
    """
    stages = plant_info.get("growth_stages", [])
    if not stages:
        return {"stage": "unknown", "fert": "NPK", "water_need": "normal", "note": "无阶段数据"}

    for s in stages:
        days = s.get("days", [0, 0])
        start_day = days[0] if isinstance(days, (list, tuple)) and len(days) > 0 else 0
        end_day = days[1] if isinstance(days, (list, tuple)) and len(days) > 1 else 999

        if start_day <= days_since_planting <= end_day:
            return s

    # 超出所有阶段范围，返回最后一个
    return stages[-1]


def calc_days_since_planting():
    """计算从种植日期到今天的天数"""
    import time
    planting = PLANTING_DATE  # (年, 月, 日)
    now = time.localtime()

    try:
        then_sec = time.mktime((planting[0], planting[1], planting[2], 0, 0, 0, 0, 0))
        now_sec = time.mktime((now[0], now[1], now[2], 0, 0, 0, 0, 0))
        days = int((now_sec - then_sec) / 86400)
        return max(0, days)
    except (ValueError, OverflowError):
        days = (now[0] - planting[0]) * 365 + (now[1] - planting[1]) * 30 + (now[2] - planting[2])
        return max(0, days)
