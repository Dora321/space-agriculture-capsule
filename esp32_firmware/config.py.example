# ============ 温度安全护栏 ============
# 超过 TEMP_HIGH_C 视为高温，跳过浇水避免叶面灼伤 + 闷根
# 低于 TEMP_LOW_C 视为低温，跳过浇水避免冻根
# 注：太空舱内温度异常通常表示热控失效，决策上保守为先
TEMP_HIGH_C = 35   # 高温警戒线（℃）
TEMP_LOW_C = 8     # 低温警戒线（℃）

# ============ 植物数据库 ============
# PLANT_DB 已迁移至 plants.json（节省 RAM）
# 如需添加新植物，请编辑 plants.json 文件

# ============ 植物列表（有序，供独立按钮菜单使用，含 8 种植物） ============
PLANT_LIST = [
    "生菜",      # 0: 叶菜
    "小白菜",    # 1: 叶菜
    "菠菜",      # 2: 叶菜
    "韭菜",      # 3: 叶菜
    "番茄",      # 4: 果菜
    "辣椒",      # 5: 果菜
    "黄瓜",      # 6: 果菜
    "茄子",      # 7: 果菜
]


def get_plant_name(index):
    """根据索引获取植物名称（0-7，共 8 种）"""
    return PLANT_LIST[index] if 0 <= index < len(PLANT_LIST) else "生菜"  # 默认返回生菜


def get_plant_info(plant_name):
    """获取植物参数（动态加载，避免占用大量内存）"""
    import ujson
    import gc

    plant_data = None
    try:
        with open('plants.json', 'r', encoding='utf-8') as f:
            db = ujson.load(f)
            plant_data = db.get(plant_name)
            if not plant_data:
                plant_data = db.get("生菜")
    except Exception as e:
        print(f"Error loading plants.json: {e}")
        # Fallback minimal data if file missing or corrupt
        plant_data = {
            "soil_threshold": 30,
            "light_min": 30, "light_opt": 50, "light_hours": [6, 8],
            "water_sec": 8,
            "growth_stages": [{"days": [0, 999], "stage": "vegetative", "fert": "NPK", "water_need": "normal", "note": ""}]
        }

    # 彻底释放包含整个 JSON 的 db 字典内存
    gc.collect()
    return plant_data


def get_growth_stage(plant_info, days_since_planting):
    """
    根据种植天数获取当前生长阶段
    返回: 当前阶段字典，包含 stage/fert/water_need/note
    """
    stages = plant_info.get("growth_stages", [])
    if not stages:
        return {"stage": "unknown", "fert": "NPK", "water_need": "normal", "note": "无阶段数据"}

    for s in stages:
        days = s.get("days", [0, 0])
        start_day = days[0] if isinstance(days, (list, tuple)) and len(days) > 0 else 0
        end_day = days[1] if isinstance(days, (list, tuple)) and len(days) > 1 else 999

        if start_day <= days_since_planting <= end_day:
            return s

    # 超出所有阶段范围，返回最后一个
    return stages[-1]


def calc_days_since_planting():
    """计算从种植日期到今天的天数"""
    import time
    planting = PLANTING_DATE  # (年, 月, 日)
    now = time.localtime()

    try:
        then_sec = time.mktime((planting[0], planting[1], planting[2], 0, 0, 0, 0, 0))
        now_sec = time.mktime((now[0], now[1], now[2], 0, 0, 0, 0, 0))
        days = int((now_sec - then_sec) / 86400)
        return max(0, days)
    except (ValueError, OverflowError):
        days = (now[0] - planting[0]) * 365 + (now[1] - planting[1]) * 30 + (now[2] - planting[2])
        return max(0, days)
